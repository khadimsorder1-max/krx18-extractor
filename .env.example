# KRX18 Premium Bot v6 — Environment Variables

# ─── Required ───────────────────────────────────────────────────
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
ADMIN_CHAT_ID=123456789

# ─── Optional (recommended) ─────────────────────────────────────
WEBHOOK_SECRET=my_random_secret_string_here
ALLOWED_USERS=123456789,987654321

# ─── Direct Stream feature (required for Watch Online Direct) ───
GITHUB_TOKEN=ghp_your_github_personal_access_token
GITHUB_REPO=your-username/krx18-extractor

# ─── Proxy Worker URL (required for downloads to work) ─────────
# Deploy proxy/ folder as a separate Cloudflare Worker, then set:
PROXY_WORKER_URL=https://krx18-proxy.your-subdomain.workers.dev

# ─── Mini App URL (required for menu button) ───────────────────
# After deploying the bot worker, set:
WEBAPP_URL=https://krx18-bot.your-subdomain.workers.dev/webapp/index.html

# ─── KV namespace (optional, for caching + favorites) ──────────
# Create with: wrangler kv namespace create CACHE_KV
# Then paste the ID in wrangler.toml

# ─── Debug ──────────────────────────────────────────────────────
DEBUG=0
