{
  "root": true,
  "env": {
    "es2022": true,
    "browser": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "globals": {
    "crypto": "readonly",
    "fetch": "readonly",
    "URL": "readonly",
    "btoa": "readonly",
    "atob": "readonly",
    "setTimeout": "readonly",
    "clearTimeout": "readonly",
    "console": "readonly"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-undef": "error",
    "no-redeclare": "error",
    "prefer-const": "warn",
    "eqeqeq": ["warn", "smart"],
    "no-var": "error"
  },
  "ignorePatterns": ["node_modules/", "extractor/", "dist/"]
}
